# ======================================================================
# El Buen Sabor - Configuración de la Aplicación
# ======================================================================
# Copia este archivo como 'application.properties' y completa los valores.
#   cp application.properties.example application.properties
# ======================================================================

spring.application.name=elbuensabor

# ================================
# Database Configuration
# ================================
# URL de conexión a MySQL. La base de datos se crea automáticamente si no existe.
spring.datasource.url=jdbc:mysql://localhost:3306/el_buen_sabor?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# ⚠️ Reemplazar con tus credenciales de MySQL
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_MYSQL
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ================================
# JPA/Hibernate Configuration
# ================================
spring.jpa.properties.hibernate.hbm2ddl.auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.jpa.database-platform=org.hibernate.dialect.MySQL8Dialect
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.jdbc.time_zone=UTC
spring.jpa.defer-datasource-initialization=true
spring.sql.init.mode=always

# ================================
# DevTools Configuration
# ================================
spring.devtools.restart.enabled=true
spring.devtools.livereload.enabled=true

# ================================
# File Upload Configuration
# ================================
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=5MB

# ================================
# Spring Mail Configuration
# ================================
# Se utiliza para el envío de correos de restablecimiento de contraseña.
# ⚠️ Para Gmail, se requiere una "Contraseña de aplicación" (App Password).
#     Generarla en: https://myaccount.google.com/apppasswords
#     (requiere tener verificación en dos pasos activada)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=TU_EMAIL@gmail.com
spring.mail.password=TU_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com
spring.mail.test-connection=false

# ================================
# Logging Configuration
# ================================
logging.level.root=INFO
logging.level.com.elbuensabor=INFO
logging.level.com.elbuensabor.config=DEBUG
logging.level.org.springframework.security=WARN
logging.level.org.hibernate.SQL=WARN
logging.level.org.hibernate.type=WARN
spring.websecurity.debug=false
logging.pattern.console=%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n

# ================================
# Custom Application Properties
# ================================

# Directorio donde se almacenan las imágenes subidas
app.upload.dir=src/main/resources/static/img/
app.public.img-path=/img/

# Orígenes permitidos por CORS (URL del frontend)
web.cors.allowed-origins=http://localhost:5173

# ================================
# JWT Security
# ================================
# ⚠️ IMPORTANTE: Generar una clave secreta propia de al menos 256 bits (64 caracteres hex).
#     Podés generar una con: openssl rand -hex 48
#     O desde Java: java -e "import java.security.SecureRandom; var b=new byte[48]; new SecureRandom().nextBytes(b); System.out.println(java.util.HexFormat.of().formatHex(b));"
application.security.jwt.secret-key=TU_JWT_SECRET_KEY_DE_AL_MENOS_256_BITS

# Expiración del token JWT en milisegundos (24 horas = 86400000)
application.security.jwt.expiration=86400000

# Expiración del token de restablecimiento de contraseña (10 minutos = 600000)
application.security.jwt.reset-token.expiration=600000

# URL base de la aplicación (usada para construir URLs de imágenes, etc.)
app.base.url=http://localhost:8080
